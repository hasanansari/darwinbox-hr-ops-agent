# Required only for Policy Agent's real RAG answer generation
# (policies/rag.py). Every other agent in this system is statistical,
# rule-based, or a learned linear policy and makes no LLM calls at all --
# see eval/cost_tracking.py for why. Without this set, Policy Agent still
# runs retrieval and reports a clear "no_api_key_configured" status
# instead of crashing.
ANTHROPIC_API_KEY=

# Optional. How long the HITL gate (agents/hitl_agent.py) blocks per scan
# waiting for a human decision via the Streamlit app before falling back
# to a safe default. Production default is 120 seconds; agents/demo.py
# overrides this to 30 seconds for faster demo runs.
HITL_TIMEOUT_SECONDS=120

# Optional. How often the HITL gate polls the shared SQLite store while
# waiting.
HITL_POLL_INTERVAL_SECONDS=2
